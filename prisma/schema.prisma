generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String
  role       String
  department String
  createdAt  DateTime @default(now())
}

model Goal {
  id          String   @id @default(cuid())
  title       String
  description String
  status      String
  progress    Int
  department  String
  createdAt   DateTime @default(now())
}